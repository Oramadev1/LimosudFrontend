{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "env": {
    "NEXT_PUBLIC_API_URL": "https://api.limosudcars.com/api",
    "NEXT_PUBLIC_SITE_URL": "https://www.limosudcars.com",
    "NEXT_PUBLIC_ADMIN_URL": "https://portal-9x.limosudcars.com/login"
  },
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "limosudcars.com" }],
      "destination": "https://www.limosudcars.com/:path*",
      "permanent": true
    }
  ]
}
