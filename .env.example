# Public site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Browser calls same-origin /api; Next.js proxies to Laravel
NEXT_PUBLIC_API_URL=/api

# Local development
LARAVEL_API_URL=http://127.0.0.1:8000/api

# Production (Vercel): use https://api.limosudcars.com/api
